{
  "name": "taiga-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Taiga project management - supports projects, sprints, user stories, tasks, issues and epics",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.1"
  }
}
